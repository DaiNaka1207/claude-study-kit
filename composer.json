{
    "name": "dainaka1207/claude-study-kit",
    "description": "Claude Code learning environment for any project. Adds /study, /hint, /review, /next, /diagnose skills to Claude Code.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.1"
    },
    "autoload": {
        "psr-4": {
            "ClaudeStudyKit\\": "src/"
        }
    },
    "scripts": {
        "post-install-cmd": "ClaudeStudyKit\\Installer::install",
        "post-update-cmd": "ClaudeStudyKit\\Installer::install"
    },
    "extra": {
        "claude-study-kit": {
            "stubs-dir": "stubs"
        }
    }
}
